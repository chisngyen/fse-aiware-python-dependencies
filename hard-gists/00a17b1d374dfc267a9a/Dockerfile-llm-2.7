# FROM is the found expected Python version
FROM python:2.7
# Set the working directory to /app
WORKDIR /app
# Add install commands for all of the python modules
RUN ["pip","install","--upgrade","pip"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","pymc3==3.10.0"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","theano==0.10.0beta4"]
RUN ["pip","install","--trusted-host","pypi.python.org","--default-timeout=100","scipy==1.8.0"]
# Copy the specified directory to /app
COPY snippet.py /app
# Run the specified python file
CMD ["python", "/app/snippet.py"]